@model Archive.Web.ViewModels.Feed.PostComposerViewModel
@{
    ViewData["Title"] = "Sửa bài viết";
}

<section class="page-shell narrow-page">
    <div class="archive-card edit-shell-card">
        <span class="eyebrow-pill">Edit post</span>
        <h1 class="page-title mt-3">Chỉnh sửa bài viết</h1>
        <form asp-action="Edit" asp-route-id="@ViewBag.PostId" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control form-control-soft composer-textarea"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="TopicId" class="form-label">Topic</label>
                    <select asp-for="TopicId" asp-items="Model.TopicOptions" class="form-select form-control-soft">
                        <option value="">Chọn topic</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ImageFile" class="form-label">Ảnh mới</label>
                    <input asp-for="ImageFile" class="form-control form-control-soft" accept="image/*" />
                </div>
            </div>
            <div class="d-flex gap-3 mt-4">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <svg class="icon"><use href="#i-edit"></use></svg>
                    <span>Lưu thay đổi</span>
                </button>
                <a asp-action="Details" asp-route-id="@ViewBag.PostId" class="btn btn-soft rounded-pill px-4">Quay lại bài viết</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
