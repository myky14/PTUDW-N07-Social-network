@{
    ViewData["Title"] = "Giới thiệu";
}

<section class="page-shell narrow-page">
    <div class="archive-card p-4 p-lg-5">
        <span class="eyebrow-pill">ARCHIVE</span>
        <h1 class="page-title mt-3">ARCHIVE là gì?</h1>
        <p class="lead">
            Đây là một đồ án môn học nhóm “Mạng xã hội”, lấy cảm hứng từ Threads nhưng thu gọn phạm vi để dễ chạy,
            dễ demo, đúng chuẩn MVC và không over-engineering.
        </p>
        <div class="soft-inline-note mt-3">Slogan thương hiệu: <strong>Một nơi để nói khẽ</strong></div>

        <div class="row g-4 mt-2">
            <div class="col-md-6">
                <div class="soft-panel h-100">
                    <h3>Tính năng người dùng</h3>
                    <ul class="soft-list">
                        <li>Đăng bài viết ngắn và ảnh</li>
                        <li>Like, comment, repost, quote</li>
                        <li>Theo dõi người dùng khác</li>
                        <li>Xem feed, profile, tìm kiếm</li>
                        <li>Báo cáo bài viết hoặc tài khoản</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-6">
                <div class="soft-panel h-100">
                    <h3>Tính năng quản trị</h3>
                    <ul class="soft-list">
                        <li>Dashboard thống kê cơ bản</li>
                        <li>Quản lý user</li>
                        <li>Quản lý post</li>
                        <li>Quản lý topic</li>
                        <li>Ẩn nội dung và khóa tài khoản</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="soft-divider"></div>

        <h3>Stack đã chọn</h3>
        <p>
            ASP.NET Core MVC + Razor Views + Bootstrap + EF Core + SQLite + AJAX JSON.
            Đây là lựa chọn gọn, đúng yêu cầu môn, dễ chạy trong VS Code và không yêu cầu setup phức tạp.
        </p>
    </div>
</section>
