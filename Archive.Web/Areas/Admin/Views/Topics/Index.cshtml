@model List<Archive.Web.ViewModels.Admin.AdminTopicRowViewModel>
@{
    ViewData["Title"] = "Quản lý topics";
    var topicForm = ViewBag.TopicForm as Archive.Web.ViewModels.Admin.EditTopicViewModel ?? new Archive.Web.ViewModels.Admin.EditTopicViewModel();
}

<section class="page-shell">
    <div class="admin-header">
        <div>
            <span class="eyebrow-pill">Quản trị</span>
            <h1 class="page-title mt-3">Quản lý chủ đề</h1>
        </div>
        <div class="admin-nav">
            <a asp-controller="Dashboard" asp-action="Index"><svg class="icon"><use href="#i-grid"></use></svg><span>Tổng quan</span></a>
            <a asp-controller="Users" asp-action="Index"><svg class="icon"><use href="#i-users"></use></svg><span>Người dùng</span></a>
            <a asp-controller="Posts" asp-action="Index"><svg class="icon"><use href="#i-comment"></use></svg><span>Bài viết</span></a>
            <a asp-controller="Topics" asp-action="Index" class="active"><svg class="icon"><use href="#i-tag"></use></svg><span>Chủ đề</span></a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="archive-card">
                <span class="eyebrow-pill">Chủ đề mới</span>
                <h3 class="mt-3">Tạo chủ đề</h3>
                <form asp-action="Save" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="topicName">Tên</label>
                        <input id="topicName" name="Name" value="@topicForm.Name" class="form-control form-control-soft" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="topicSlug">Slug</label>
                        <input id="topicSlug" name="Slug" value="@topicForm.Slug" class="form-control form-control-soft" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="topicDescription">Mô tả</label>
                        <textarea id="topicDescription" name="Description" class="form-control form-control-soft" rows="4">@topicForm.Description</textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" name="IsVisible" class="form-check-input" value="true" @(topicForm.IsVisible ? "checked" : "") />
                        <label class="form-check-label">Hiển thị chủ đề</label>
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu chủ đề</button>
                </form>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="archive-card admin-table-card">
                <div class="table-responsive">
                    <table class="table admin-table align-middle">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th>Slug</th>
                                <th>Bài viết</th>
                                <th>Trạng thái</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var topic in Model)
                            {
                                <tr>
                                    <td>@topic.Name</td>
                                    <td>@topic.Slug</td>
                                    <td>@topic.PostCount</td>
                                    <td>
                                        @if (topic.IsVisible)
                                        {
                                            <span class="badge text-bg-success rounded-pill">Hiển thị</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary rounded-pill">Đã ẩn</span>
                                        }
                                    </td>
                                    <td><a asp-action="Edit" asp-route-id="@topic.Id" class="btn btn-soft btn-sm rounded-pill">Sửa</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
